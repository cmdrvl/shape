{
  "schema_version": "operator.v0",
  "name": "shape",
  "version": "0.1.0",
  "description": "Structural comparability gate — deterministically answers whether two CSV datasets can be compared",
  "repository": "https://github.com/cmdrvl/shape",
  "license": "MIT",

  "invocation": {
    "binary": "shape",
    "output_mode": "report",
    "output_schema": "shape.v0",
    "json_flag": "--json"
  },

  "arguments": [
    { "name": "old", "type": "file_path", "required": true, "position": 0, "description": "Old CSV file" },
    { "name": "new", "type": "file_path", "required": true, "position": 1, "description": "New CSV file" }
  ],

  "options": [
    { "name": "key", "flag": "--key", "type": "string", "description": "Key column for alignment check" },
    { "name": "delimiter", "flag": "--delimiter", "type": "string", "description": "Force CSV delimiter for both files" },
    { "name": "profile", "flag": "--profile", "type": "file_path", "description": "Scope checks to profile columns" },
    { "name": "profile_id", "flag": "--profile-id", "type": "string", "description": "Profile ID (resolved from search path)" },
    { "name": "lock", "flag": "--lock", "type": "file_path", "repeatable": true, "description": "Verify inputs are members of these lockfiles" },
    { "name": "max_rows", "flag": "--max-rows", "type": "integer", "description": "Refuse if input exceeds N rows" },
    { "name": "max_bytes", "flag": "--max-bytes", "type": "integer", "description": "Refuse if input file exceeds N bytes" }
  ],

  "exit_codes": {
    "0": { "meaning": "COMPATIBLE", "domain": "positive" },
    "1": { "meaning": "INCOMPATIBLE", "domain": "negative" },
    "2": { "meaning": "REFUSAL", "domain": "error" }
  },

  "refusals": [
    {
      "code": "E_IO",
      "message": "Cannot read input file",
      "action": "escalate"
    },
    {
      "code": "E_ENCODING",
      "message": "Unsupported encoding (UTF-16/32 BOM or NUL bytes)",
      "action": "escalate"
    },
    {
      "code": "E_CSV_PARSE",
      "message": "CSV parse failure",
      "action": "escalate"
    },
    {
      "code": "E_EMPTY",
      "message": "One or both files are empty",
      "action": "escalate"
    },
    {
      "code": "E_HEADERS",
      "message": "Missing header or duplicate headers",
      "action": "escalate"
    },
    {
      "code": "E_DIALECT",
      "message": "Delimiter ambiguous or undetectable",
      "action": "retry_with_flag",
      "flag": "--delimiter",
      "value_source": null
    },
    {
      "code": "E_AMBIGUOUS_PROFILE",
      "message": "Both --profile and --profile-id were provided",
      "action": "adjust_input"
    },
    {
      "code": "E_INPUT_NOT_LOCKED",
      "message": "Input file not present in provided lockfiles",
      "action": "escalate"
    },
    {
      "code": "E_INPUT_DRIFT",
      "message": "Input file hash does not match locked member",
      "action": "escalate"
    },
    {
      "code": "E_TOO_LARGE",
      "message": "Input exceeds row or byte limit",
      "action": "retry_with_flag",
      "flag_source": "detail.limit_flag",
      "value_source": "detail.suggested_limit"
    }
  ],

  "capabilities": {
    "formats": ["csv"],
    "profile_aware": true,
    "streaming": false
  },

  "pipeline": {
    "upstream": [],
    "downstream": ["rvl", "compare", "verify", "assess"]
  }
}
